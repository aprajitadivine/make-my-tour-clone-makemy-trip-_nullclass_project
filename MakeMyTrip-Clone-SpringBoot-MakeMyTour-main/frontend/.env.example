# ============================================================
# Frontend Environment Variables — MakeMyTour
# ============================================================
# Copy this file to .env.local for local development (git-ignored).
# In production (Netlify), add these as Site → Build & Deploy → Environment Variables.
#
# IMPORTANT: All variables MUST start with VITE_ to be exposed to the browser.
# ============================================================

# Base URL of the deployed Spring Boot backend.
# Leave empty (or don't create .env.local at all) to use the Vite dev-server
# proxy (/api → http://localhost:8080) during local development.
#
# Production (Render) — set this in the Netlify dashboard, NOT in netlify.toml:
#   Site configuration → Environment variables → VITE_API_BASE_URL
#   Value: https://<your-render-service>.onrender.com/api
#
# You can verify the backend is reachable by visiting:
#   https://<your-render-service>.onrender.com/api/health
# It should return {"status":"UP"} immediately.
#
VITE_API_BASE_URL=https://makemytour-backend.onrender.com/api

# Razorpay publishable key (safe to expose to the browser).
# The backend reads RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET from environment variables.
# Use your Razorpay test key for development (starts with rzp_test_) or live key for production.
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
